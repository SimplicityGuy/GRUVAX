# GRUVAX environment file — copy to `.env` and fill in real values.
#
# `docker compose up` reads `.env` automatically; pydantic-settings also
# reads it when running `uv run gruvax-*` outside Docker. NEVER commit `.env`.
#
# ──────────────────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────────────────
# SQLAlchemy / Alembic async form: postgresql+psycopg://user:pass@host/db
# Boot fails with a clear pydantic ValidationError if this is missing.
DATABASE_URL=postgresql+psycopg://gruvax:gruvax@gruvax-dev-pg:5432/gruvax

# ──────────────────────────────────────────────────────────────────────────
# Admin session signing (SESSION_SECRET — Plan 03)
# ──────────────────────────────────────────────────────────────────────────
# Signs the admin session cookie. Boot fails if missing.
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=replace-me-with-a-real-32-byte-urlsafe-token

# ──────────────────────────────────────────────────────────────────────────
# discogsography integration (Plan 01-01 / D-18)
# ──────────────────────────────────────────────────────────────────────────
# The HTTP API base URL of the discogsography service. Prod points at the
# real discogsography-api; dev compose defaults to the in-stack
# fake-discogsography sibling service. Boot fails if missing.
DISCOGSOGRAPHY_BASE_URL=http://fake-discogsography:8004

# ──────────────────────────────────────────────────────────────────────────
# Fernet key for PAT-at-rest encryption (Plan 01-01 / D-01)
# ──────────────────────────────────────────────────────────────────────────
# URL-safe base64-encoded 32 random bytes. Boot fails if missing or
# malformed (a Fernet validator runs in gruvax.settings on every startup).
# Generate ONCE per deployment and persist:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Rotating the key orphans every existing profiles.app_token_encrypted row;
# a P4 utility will land for the re-encrypt flow. For now, treat as a
# permanent per-deployment value.
GRUVAX_SECRET_KEY=replace-me-with-Fernet.generate_key().decode()

# ──────────────────────────────────────────────────────────────────────────
# MQTT (Mosquitto sidecar — Phase 6+ hardware milestone)
# ──────────────────────────────────────────────────────────────────────────
# Defaults work for `docker compose up`; override only when running outside
# the stack or against a remote broker.
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=gruvax-api
MQTT_PASSWORD=

# ──────────────────────────────────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
