{
  "$schema": "https://gruvax.local/tokens/v1",
  "animation": {
    "duration": {
      "base": "250ms",
      "enter": "600ms",
      "fast": "150ms",
      "ledOff": "500ms",
      "ledOn": "300ms",
      "slow": "400ms"
    },
    "easing": {
      "accelerate": "cubic-bezier(0.4, 0.0, 1.0, 1)",
      "decelerate": "cubic-bezier(0.0, 0.0, 0.2, 1)",
      "ledOff": "cubic-bezier(0.4, 0.0, 0.2, 1)",
      "ledOn": "cubic-bezier(0.34, 1.56, 0.64, 1)",
      "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)",
      "standard": "cubic-bezier(0.4, 0.0, 0.2, 1)"
    }
  },
  "borderRadius": {
    "lg": "12px",
    "md": "8px",
    "pill": "9999px",
    "sm": "4px",
    "xl": "16px"
  },
  "color": {
    "border": {
      "faint": {
        "value": "#E5EEF7"
      },
      "light": {
        "value": "#C5DBF0"
      },
      "strong": {
        "value": "#0051A2"
      }
    },
    "brand": {
      "blue": {
        "comment": "Primary brand \u00b7 borders \u00b7 wordmark",
        "value": "#0051A2"
      },
      "blueDark": {
        "comment": "Hover states \u00b7 pressed \u00b7 deep backgrounds",
        "value": "#003D7A"
      },
      "blueDarker": {
        "comment": "Active / deepest accent",
        "value": "#002855"
      },
      "blueFaint": {
        "comment": "Hover background \u00b7 selected row bg",
        "value": "#EEF5FB"
      },
      "blueLight": {
        "comment": "Dim cell fill \u00b7 inactive states",
        "value": "#D8E8F5"
      },
      "offWhite": {
        "comment": "Secondary surface",
        "value": "#F7F9FC"
      },
      "overlayScrim": {
        "comment": "Modal / bottom-sheet backdrop \u00b7 blue-darker @ 55%",
        "value": "rgba(0, 40, 85, 0.55)"
      },
      "white": {
        "comment": "Primary background",
        "value": "#FFFFFF"
      },
      "yellow": {
        "comment": "LED lit \u00b7 accent \u00b7 CTAs",
        "value": "#FFDA00"
      },
      "yellowDark": {
        "comment": "LED lit border \u00b7 yellow hover",
        "value": "#E6B800"
      },
      "yellowFaint": {
        "comment": "Subtle highlight background",
        "value": "rgba(255, 218, 0, 0.12)"
      },
      "yellowGlow": {
        "comment": "LED ambient glow",
        "value": "rgba(255, 218, 0, 0.35)"
      }
    },
    "cell": {
      "dim": {
        "comment": "Default / unlit cube",
        "value": "#D8E8F5"
      },
      "dimBorder": {
        "value": "#B8D0E8"
      },
      "empty": {
        "comment": "Unconfigured cube",
        "value": "#F2F2F2"
      },
      "emptyBorder": {
        "comment": "Empty cube border (dashed)",
        "value": "#DDDDDD"
      },
      "hover": {
        "value": "#EEF5FB"
      },
      "lit": {
        "comment": "Active / found cube",
        "value": "#FFDA00"
      },
      "litBorder": {
        "value": "#E6B800"
      },
      "selected": {
        "value": "#003D7A"
      }
    },
    "semantic": {
      "error": {
        "value": "#C0392B"
      },
      "success": {
        "value": "#1A7A4A"
      },
      "warning": {
        "value": "#E6A800"
      }
    },
    "text": {
      "faint": {
        "value": "#999999"
      },
      "muted": {
        "value": "#777777"
      },
      "primary": {
        "value": "#0051A2"
      },
      "secondary": {
        "value": "#555555"
      }
    }
  },
  "grid": {
    "borderRadius": {
      "lg": "6px",
      "md": "4px",
      "sm": "3px",
      "xl": "8px"
    },
    "cell": {
      "sizeLg": "56px",
      "sizeMd": "40px",
      "sizeSm": "28px",
      "sizeXl": "80px"
    },
    "columns": 4,
    "gap": {
      "lg": "8px",
      "md": "6px",
      "sm": "4px",
      "xl": "12px"
    },
    "rows": 4
  },
  "logo": {
    "assets": {
      "banner": "gruvax-logo-banner.svg",
      "favicon": "gruvax-favicon.svg",
      "icon": "gruvax-logo-icon.svg",
      "square": "gruvax-logo-square.svg"
    },
    "clearspace": "12.5%",
    "minWidth": {
      "banner": "240px",
      "icon": "24px",
      "square": "120px"
    }
  },
  "name": "GRUVAX Design Tokens",
  "shadow": {
    "led": "0 0 12px rgba(255, 218, 0, 0.6), 0 0 24px rgba(255, 218, 0, 0.3)",
    "lg": "0 8px 24px rgba(0, 81, 162, 0.15)",
    "md": "0 4px 12px rgba(0, 81, 162, 0.12)",
    "sm": "0 1px 3px rgba(0, 81, 162, 0.10)"
  },
  "spacing": {
    "1": "4px",
    "10": "128px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "24px",
    "6": "32px",
    "7": "48px",
    "8": "64px",
    "9": "96px"
  },
  "typography": {
    "fontFamily": {
      "display": "'Barlow Condensed', 'Arial Narrow', Arial, sans-serif",
      "mono": "'DM Mono', 'Menlo', 'Monaco', monospace",
      "ui": "'Space Grotesk', system-ui, -apple-system, sans-serif"
    },
    "fontSize": {
      "body": "16px",
      "bodyLg": "18px",
      "bodySm": "14px",
      "caption": "12px",
      "displayLg": "36px",
      "displayMd": "24px",
      "displaySm": "16px",
      "displayXl": "48px",
      "label": "11px",
      "mono": "14px",
      "monoLg": "16px",
      "monoSm": "11px",
      "wordmark": "84px"
    },
    "fontWeight": {
      "black": 900,
      "bold": 700,
      "medium": 500,
      "regular": 400
    },
    "letterSpacing": {
      "descriptor": "0.20em",
      "display": "0.02em",
      "label": "0.14em",
      "wordmark": "0.04em"
    },
    "lineHeight": {
      "normal": 1.5,
      "relaxed": 1.7,
      "tight": 1.1
    }
  },
  "version": "1.0.0",
  "zIndex": {
    "admin": 50,
    "base": 0,
    "grid": 10,
    "modal": 30,
    "overlay": 20,
    "screensaver": 40
  }
}
